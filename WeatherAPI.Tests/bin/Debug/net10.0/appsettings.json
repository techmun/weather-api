{
  "ConnectionStrings": {
    "WeatherDb": "Data Source=weather.db"
  },
  "WeatherApi": {
    "BaseUrl": "https://api-open.data.gov.sg/v2/real-time/api/",
    "PollingIntervalMinutes": 30,
    "DefaultHistoricalLookbackDays": 2
  },
  "BearerToken": {
    "Token": ""
  },
  "UpstreamApi": {
    "HeaderName": "x-api-key",
    "Key": ""
  },
  "Cors": {
    "AllowedOrigins": []
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
